# ============================================================
# Enterprise Intelligent Incident Diagnosis Platform
# Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   uvicorn app.main:app --reload
# ============================================================

# Application
ENVIRONMENT=development   # development | staging | production
DEBUG=false

# Logging
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ============================================================
# LLM Integration Layer
# ============================================================
# Set LLM_PROVIDER to switch between providers.
# Changing this value is the ONLY code-free way to switch LLM backends.
# Business logic, orchestrator, and all engines remain untouched.
# ============================================================

# Active provider — choose one: gemini | local_llama | mock
LLM_PROVIDER=mock

# ------------------------------------------------------------
# Gemini Provider (Google GenAI)
# Used on personal laptops and development environments.
# Requires internet access.
# ------------------------------------------------------------
# GEMINI_API_KEY=AIzaSy...          # Your Google GenAI API key (required for gemini)
# GEMINI_MODEL=gemini-2.0-flash     # Model identifier (default: gemini-2.0-flash)

# ------------------------------------------------------------
# Local Llama Provider (Barclays On-Premises)
# Used inside Barclays office — no internet required.
# See docs/LLM_SWITCH_GUIDE.md for migration instructions.
# ------------------------------------------------------------
# LOCAL_LLM_ENDPOINT=http://llama-server.barclays.internal:8080/v1/chat/completions
# LOCAL_LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# LOCAL_LLM_TIMEOUT=30.0

# ------------------------------------------------------------
# Mock Provider
# Fully deterministic, no external dependencies.
# Default for local development and CI pipelines.
# ------------------------------------------------------------
# (No additional configuration required for mock)

# ============================================================
# Future — uncomment when PostgreSQL sprint begins
# ============================================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ai_analysis_db
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here

# ============================================================
# Future — uncomment when AWS sprint begins
# ============================================================
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
